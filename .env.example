# ══════════════════════════════════════════════════════════════════
# LLM Gateway — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Provider API Keys ─────────────────────────────────────────────
# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Base URL for local Ollama instance (no trailing slash)
OLLAMA_BASE_URL=http://localhost:11434

# ── Infrastructure ────────────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://redis:6379

# ── Budget & Routing ──────────────────────────────────────────────
# Monthly spend limit in USD — AUTO strategy switches to CHEAPEST at 80%
MONTHLY_BUDGET_USD=50.0

# Default routing strategy: cheapest | fastest | quality | balanced | auto
DEFAULT_STRATEGY=balanced

# ── Semantic Cache ────────────────────────────────────────────────
# Cosine similarity threshold for cache hits (0.0–1.0)
CACHE_SIMILARITY_THRESHOLD=0.92

# Time-to-live for cached responses in seconds
CACHE_TTL_SECONDS=3600

# ── Application ───────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Runtime environment: development | staging | production
ENVIRONMENT=development
